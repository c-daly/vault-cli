#!/usr/bin/env zsh
set -euo pipefail

# --- Config ---
VAULT_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/vault-cli/config"
if [[ -f "$VAULT_CONFIG" ]]; then
    source "$VAULT_CONFIG"
fi

VAULT_DIR="${VAULT_DIR:-}"
EDITOR="${VAULT_EDITOR:-${EDITOR:-nvim}}"

# Recap/weekly config
REPOS_DIR="${VAULT_REPOS_DIR:-$HOME/projects}"
HIST_FILE="${HISTFILE:-$HOME/.zsh_history}"
GCAL_ENABLED="${VAULT_GCAL_ENABLED:-true}"
CLAUDE_PROJECTS_DIR="$HOME/.claude/projects"

if [[ -z "$VAULT_DIR" ]]; then
    echo "Error: VAULT_DIR not set. Run setup.sh or set VAULT_DIR in $VAULT_CONFIG" >&2
    exit 1
fi

if [[ ! -d "$VAULT_DIR" ]]; then
    echo "Error: VAULT_DIR '$VAULT_DIR' does not exist" >&2
    exit 1
fi

# --- Helpers ---
vault_date() { date +%Y-%m-%d; }
vault_time() { date +%H:%M; }
vault_hostname() { hostname -s 2>/dev/null || hostname; }

# Cross-platform date helpers (macOS vs Linux/WSL)
if [[ "$(uname)" == "Darwin" ]]; then
    _date_offset() { date -j -v"${2}d" -f "%Y-%m-%d" "$1" +%Y-%m-%d; }
    _date_fmt()    { date -j -f "%Y-%m-%d" "$1" "$2"; }
    _date_epoch()  { date -j -f "%Y-%m-%d %H:%M:%S" "$1" "+%s"; }
    _date_yesterday() { date -v-1d +%Y-%m-%d; }
else
    _date_offset() { date -d "$1 ${2} days" +%Y-%m-%d; }
    _date_fmt()    { date -d "$1" "$2"; }
    _date_epoch()  { date -d "$1" "+%s"; }
    _date_yesterday() { date -d "yesterday" +%Y-%m-%d; }
fi

# --- Subcommands ---

cmd_help() {
    cat <<'HELP'
Usage: vault <command> [options]

Commands:
  add <text> [-t type]   Quick capture to today's daily file
  process [date]         Review and categorize captures
  process --commit       Split categorized entries into notes
  edit [-t type]         Create note from template, open in editor
  daily                  Create/open today's daily note
  search <query>         Search vault with fzf + ripgrep
  sync                   Git commit + pull + push
  harvest [--all] [--project <name>]  Import Claude Code sessions
  recent [N]             Show recently modified notes (default: 10)
  recap [today|yesterday|DATE]  Auto-generate daily recap from activity
  weekly [end-date]      Weekly rollup from daily recaps
  help                   Show this help
HELP
}

cmd_add() {
    local category=""
    local text=""

    # Parse args
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -t|--type) category="$2"; shift 2 ;;
            *)
                if [[ -n "$text" ]]; then
                    text="$text $1"
                else
                    text="$1"
                fi
                shift
                ;;
        esac
    done

    if [[ -z "$text" ]]; then
        echo "Usage: vault add <text> [-t type]" >&2
        exit 1
    fi

    local today
    today="$(vault_date)"
    local now
    now="$(vault_time)"
    local capture_file="$VAULT_DIR/00-inbox/$today.md"

    mkdir -p "$VAULT_DIR/00-inbox"

    {
        echo ""
        echo "## $now"
        echo "$text"
        if [[ -n "$category" ]]; then
            echo "> $category"
        fi
    } >> "$capture_file"

    echo "Captured to $today.md at $now"
}
cmd_process() {
    local target_date=""
    local do_commit=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --commit) do_commit=true; shift ;;
            *) target_date="$1"; shift ;;
        esac
    done
    [[ -z "$target_date" ]] && target_date="$(vault_date)"

    local capture_file="$VAULT_DIR/00-inbox/$target_date.md"

    if [[ ! -f "$capture_file" ]]; then
        echo "No capture file for $target_date"
        return 0
    fi

    if $do_commit; then
        _process_commit "$capture_file" "$target_date"
    else
        "$EDITOR" "$capture_file"
    fi
}

_process_commit() {
    local capture_file="$1"
    local target_date="$2"
    local count=0
    local current_time="" current_text="" current_category=""

    while IFS= read -r line || [[ -n "$line" ]]; do
        if [[ "$line" =~ ^##\ ([0-9]{2}:[0-9]{2}) ]]; then
            # Save previous entry if exists
            if [[ -n "$current_text" ]]; then
                _create_note_from_entry "$current_text" "$current_category" "$target_date" "$current_time"
                count=$((count + 1))
            fi
            current_time="${match[1]}"
            current_text=""
            current_category=""
        elif [[ "$line" == '> '* ]]; then
            local tag="${line#> }"
            if [[ "$tag" == '?'* ]]; then
                # Unconfirmed category — skip this entry
                echo "Skipping unconfirmed entry at $current_time (category: $tag)"
                current_text=""
            else
                # Confirmed category
                current_category="$tag"
            fi
        elif [[ -n "$current_time" ]]; then
            if [[ -n "$current_text" ]]; then
                current_text="$current_text
$line"
            else
                current_text="$line"
            fi
        fi
    done < "$capture_file"

    # Handle last entry
    if [[ -n "$current_text" ]]; then
        _create_note_from_entry "$current_text" "$current_category" "$target_date" "$current_time"
        count=$((count + 1))
    fi

    echo "Created $count notes from $target_date captures"

    if [[ $count -gt 0 ]]; then
        local archive_dir="$VAULT_DIR/40-archive/daily-captures"
        mkdir -p "$archive_dir"
        mv "$capture_file" "$archive_dir/$target_date.md"
        echo "Archived capture file to $archive_dir/$target_date.md"
    fi
}

_create_note_from_entry() {
    local text="$1"
    local category="${2:-fleeting}"
    local entry_date="$3"
    local entry_time="$4"

    # Trim empty lines
    text=$(echo "$text" | sed '/^$/d')
    [[ -z "$text" ]] && return

    local dest_dir
    case "$category" in
        project)   dest_dir="$VAULT_DIR/10-projects" ;;
        learning)  dest_dir="$VAULT_DIR/30-resources" ;;
        fleeting|*) dest_dir="$VAULT_DIR/00-inbox" ;;
    esac

    local first_line
    first_line=$(echo "$text" | head -1)
    local filename
    filename=$(echo "$first_line" | tr ' ' '-' | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9-' | cut -c1-60)
    [[ -z "$filename" ]] && filename="note-$entry_date-$entry_time"
    local note_file="$dest_dir/$filename.md"

    # Avoid overwriting
    if [[ -f "$note_file" ]]; then
        note_file="$dest_dir/${filename}-${entry_time}.md"
    fi

    mkdir -p "$dest_dir"

    cat > "$note_file" <<EOF
---
created: $entry_date
type: $category
---

# $first_line

$text

EOF

    echo "  -> $note_file"
}
cmd_edit() {
    local note_type=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -t|--type) note_type="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    # Prompt for type if not given
    if [[ -z "$note_type" ]]; then
        echo "Note type:"
        echo "  1) fleeting"
        echo "  2) project"
        echo "  3) learning"
        read -r "choice?> "
        case "$choice" in
            1|fleeting)  note_type="fleeting" ;;
            2|project)   note_type="project" ;;
            3|learning)  note_type="learning" ;;
            *) echo "Invalid choice"; exit 1 ;;
        esac
    fi

    local dest_dir
    case "$note_type" in
        fleeting)  dest_dir="$VAULT_DIR/00-inbox" ;;
        project)   dest_dir="$VAULT_DIR/10-projects" ;;
        learning)  dest_dir="$VAULT_DIR/30-resources" ;;
        *) dest_dir="$VAULT_DIR/00-inbox" ;;
    esac

    local today
    today="$(vault_date)"
    local template="$VAULT_DIR/_templates/$note_type.md"

    read -r "title?Title: "
    if [[ -z "$title" ]]; then
        title="Untitled $(vault_date) $(vault_time)"
    fi

    local filename
    filename="$(echo "$title" | tr ' ' '-' | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9-')"
    local note_file="$dest_dir/$filename.md"

    mkdir -p "$dest_dir"

    if [[ -f "$template" ]]; then
        sed -e "s/{{date:YYYY-MM-DD}}/$today/g" \
            -e "s/{{date}}/$today/g" \
            -e "s/{{title}}/$title/g" \
            "$template" > "$note_file"
    else
        cat > "$note_file" <<EOF
---
created: $today
type: $note_type
---

# $title

EOF
    fi

    "$EDITOR" "$note_file"
    echo "Created: $note_file"
}
cmd_daily() {
    local today
    today="$(vault_date)"
    local daily_file="$VAULT_DIR/journal/$today.md"
    local template="$VAULT_DIR/_templates/daily.md"

    mkdir -p "$VAULT_DIR/journal"

    if [[ ! -f "$daily_file" ]]; then
        if [[ -f "$template" ]]; then
            sed -e "s/{{date:YYYY-MM-DD}}/$today/g" \
                -e "s/{{date}}/$today/g" \
                -e "s/{{title}}/$today/g" \
                "$template" > "$daily_file"
        else
            cat > "$daily_file" <<EOF
---
created: $today
type: daily
---

# $today

## Today's Focus


## Notes & Ideas


## Reflections

EOF
        fi
        echo "Created daily note: $daily_file"
    fi

    "$EDITOR" "$daily_file"
}
cmd_recent() {
    local count="${1:-10}"

    cd "$VAULT_DIR"
    echo "Recently modified notes:"
    echo ""
    # Show recent git file changes with relative timestamps
    { git log --diff-filter=ACMR --name-only --format="%ar" -- '*.md' 2>/dev/null || true; } \
        | awk -v max="$count" '
            /ago/ { timestamp = $0; next }
            NF && !seen[$0]++ { printf "  %-20s %s\n", timestamp, $0; n++; if (n >= max) exit }
        ' || true

    echo ""
    echo "Today's captures:"
    local today_file="$VAULT_DIR/00-inbox/$(vault_date).md"
    if [[ -f "$today_file" ]]; then
        grep '^## ' "$today_file" 2>/dev/null | while IFS= read -r line; do
            echo "  $line"
        done
    else
        echo "  (none)"
    fi
}

cmd_search() {
    local query="${*:-}"

    if ! command -v rg &>/dev/null; then
        echo "Error: ripgrep (rg) is required for search" >&2
        exit 1
    fi
    if ! command -v fzf &>/dev/null; then
        echo "Error: fzf is required for search" >&2
        exit 1
    fi

    local selected
    if [[ -n "$query" ]]; then
        selected=$(
            rg --files-with-matches --no-messages "$query" "$VAULT_DIR" \
                --glob '!.git' --glob '!.obsidian' --glob '!.vault-cli' |
            fzf --preview "rg --context 3 --color=always '$query' {}" \
                --preview-window=right:60%:wrap \
                --query "$query"
        ) || return 0
    else
        selected=$(
            rg --files "$VAULT_DIR" \
                --glob '!.git' --glob '!.obsidian' --glob '!.vault-cli' |
            fzf --preview "head -40 {}" \
                --preview-window=right:60%:wrap
        ) || return 0
    fi

    if [[ -n "$selected" ]]; then
        "$EDITOR" "$selected"
    fi
}
cmd_sync() {
    local hostname
    hostname="$(vault_hostname)"
    local timestamp
    timestamp="$(date +%Y-%m-%d-%H%M)"

    cd "$VAULT_DIR"

    if [[ -n "$(git status --porcelain)" ]]; then
        git add -A
        git commit -m "vault sync $hostname $timestamp"
        echo "Committed changes"
    else
        echo "No local changes to commit"
    fi

    if git remote get-url origin &>/dev/null; then
        echo "Pulling..."
        git pull --rebase || {
            echo "Error: rebase conflict. Resolve manually in $VAULT_DIR" >&2
            exit 1
        }
        echo "Pushing..."
        git push
        echo "Synced."
    else
        echo "No remote configured — skipping push/pull"
    fi
}
cmd_harvest() {
    local harvest_all=false
    local project_filter=""
    local do_sync=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all) harvest_all=true; shift ;;
            --project) project_filter="$2"; shift 2 ;;
            --sync) do_sync=true; shift ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done

    if ! command -v jq &>/dev/null; then
        echo "Error: jq is required for harvest. Install with: sudo apt install jq" >&2
        exit 1
    fi

    local claude_dir="$HOME/.claude/projects"
    if [[ ! -d "$claude_dir" ]]; then
        echo "No Claude Code projects found at $claude_dir"
        return 0
    fi

    local state_file="$VAULT_DIR/.vault-harvest-state"
    local output_dir="$VAULT_DIR/30-resources/claude-sessions"
    local hostname
    hostname="$(vault_hostname)"
    local count=0

    # Load previously harvested session IDs
    typeset -A harvested
    if [[ -f "$state_file" ]] && ! $harvest_all; then
        while IFS= read -r sid; do
            harvested[$sid]=1
        done < "$state_file"
    fi

    # Process each project's session index
    for index_file in "$claude_dir"/*/sessions-index.json; do
        [[ -f "$index_file" ]] || continue

        local project_dir="$(dirname "$index_file")"
        local project_name="$(basename "$project_dir")"

        # Apply project filter
        if [[ -n "$project_filter" ]] && [[ "$project_name" != *"$project_filter"* ]]; then
            continue
        fi

        # Extract all sessions as JSON lines for efficient processing
        while IFS= read -r entry; do
            local session_id summary first_prompt created modified
            local git_branch project_path message_count full_path

            session_id=$(echo "$entry" | jq -r '.sessionId // empty' 2>/dev/null) || continue
            [[ -z "$session_id" ]] && continue

            # Skip already harvested
            if [[ -n "${harvested[$session_id]:-}" ]]; then
                continue
            fi

            message_count=$(echo "$entry" | jq -r '.messageCount // 0' 2>/dev/null) || continue

            # Skip trivial sessions
            if [[ "$message_count" -le 2 ]] 2>/dev/null; then
                echo "$session_id" >> "$state_file"
                continue
            fi

            summary=$(echo "$entry" | jq -r '.summary // "No summary"' 2>/dev/null) || summary="No summary"
            first_prompt=$(echo "$entry" | jq -r '.firstPrompt // ""' 2>/dev/null) || first_prompt=""
            created=$(echo "$entry" | jq -r '.created // empty' 2>/dev/null) || continue
            modified=$(echo "$entry" | jq -r '.modified // empty' 2>/dev/null) || modified=""
            git_branch=$(echo "$entry" | jq -r '.gitBranch // ""' 2>/dev/null) || git_branch=""
            project_path=$(echo "$entry" | jq -r '.projectPath // ""' 2>/dev/null) || project_path=""
            full_path=$(echo "$entry" | jq -r '.fullPath // ""' 2>/dev/null) || full_path=""

            # Calculate date and duration
            local session_date session_time
            session_date=$(date -d "$created" +%Y-%m-%d 2>/dev/null || echo "${created:0:10}")
            session_time=$(date -d "$created" +%H:%M 2>/dev/null || echo "00:00")
            local year_month="${session_date:0:7}"

            local duration_min="?"
            if [[ -n "$created" ]] && [[ -n "$modified" ]]; then
                local start_epoch end_epoch
                start_epoch=$(date -d "$created" +%s 2>/dev/null || echo 0)
                end_epoch=$(date -d "$modified" +%s 2>/dev/null || echo 0)
                if [[ "$start_epoch" -gt 0 ]] && [[ "$end_epoch" -gt 0 ]]; then
                    duration_min=$(( (end_epoch - start_epoch) / 60 ))
                fi
            fi

            # Readable project name from path
            local readable_project
            readable_project=$(echo "$project_path" | sed 's|.*/||')
            [[ -z "$readable_project" ]] && readable_project="$project_name"

            # Create output directory
            local out_dir="$output_dir/$year_month"
            mkdir -p "$out_dir"

            local note_file="$out_dir/${session_date}-${session_id:0:8}.md"

            # Build the note
            {
                echo "---"
                echo "created: $session_date"
                echo "type: claude-session"
                echo "machine: $hostname"
                echo "project: $project_path"
                [[ -n "$git_branch" ]] && echo "branch: $git_branch"
                echo "source: $full_path"
                echo "session_id: $session_id"
                echo "---"
                echo ""
                echo "# Claude Code Session — $session_date $session_time"
                echo ""
                echo "**Machine:** $hostname"
                echo "**Project:** $readable_project (\`$project_path\`)"
                [[ -n "$git_branch" ]] && echo "**Branch:** \`$git_branch\`"
                echo "**Duration:** ${duration_min} min | **Messages:** $message_count"
                echo "**Source:** \`$full_path\`"
                echo ""
                echo "## Summary"
                echo "$summary"
                echo ""
                echo "## First Prompt"
                echo "> $first_prompt"
                echo ""
                echo "## Related"
                echo ""
            } > "$note_file"

            echo "$session_id" >> "$state_file"
            count=$((count + 1))
        done < <(jq -c '.entries[]' "$index_file" 2>/dev/null)
    done

    echo "Harvested $count new sessions"

    if $do_sync; then
        cmd_sync
    fi
}

# --- Recap collectors ---

_collect_git_activity() {
    local target_date="$1"
    local output="" commit_count=0
    local -a repo_dirs=("${(@s/:/)REPOS_DIR}")

    local git_email
    git_email=$(git config --global user.email 2>/dev/null || echo "")

    for repos_parent in "${repo_dirs[@]}"; do
        [[ -d "$repos_parent" ]] || continue
        for repo in "$repos_parent"/*(N/); do
            [[ -d "$repo/.git" ]] || continue
            local repo_name=$(basename "$repo")
            local author_flag=""
            [[ -n "$git_email" ]] && author_flag="--author=$git_email"

            local log
            log=$(git -C "$repo" log $author_flag \
                --after="${target_date}T00:00:00" \
                --before="${target_date}T23:59:59" \
                --pretty=format:"- %s (\`%h\`)" 2>/dev/null || true)

            if [[ -n "$log" ]]; then
                local count=$(echo "$log" | wc -l | tr -d ' ')
                commit_count=$((commit_count + count))
                output+="**$repo_name** ($count commits)\n$log\n\n"
            fi
        done
    done

    if [[ -n "$output" ]]; then
        echo "$commit_count commits across repos\n"
        echo "$output"
    else
        echo "*No commits on $target_date*"
    fi
}

_collect_shell_history() {
    local target_date="$1"

    if [[ ! -f "$HIST_FILE" ]]; then
        echo "*No shell history file found*"
        return
    fi

    local start_ts end_ts
    start_ts=$(_date_epoch "$target_date 00:00:00")
    end_ts=$(_date_epoch "$target_date 23:59:59")

    local commands=()
    while IFS= read -r line; do
        if [[ "$line" =~ ^:\ ([0-9]+):[0-9]+\;(.+)$ ]]; then
            local ts="${match[1]}" cmd="${match[2]}"
            if (( ts >= start_ts && ts <= end_ts )); then
                commands+=("$cmd")
            fi
        fi
    done < "$HIST_FILE"

    if (( ${#commands[@]} == 0 )); then
        echo "*No shell commands recorded for $target_date*"
        return
    fi

    echo "${#commands[@]} commands run\n"

    local -A cmd_counts
    local notable=()
    for cmd in "${commands[@]}"; do
        local base="${cmd%% *}"
        case "$base" in
            ls|cd|pwd|clear|echo|cat|less|more) continue ;;
        esac
        cmd_counts[$base]=$(( ${cmd_counts[$base]:-0} + 1 ))
        case "$base" in
            git|docker|npm|pip|brew|cargo|make|kubectl|terraform|vault|claude)
                notable+=("$cmd") ;;
        esac
    done

    echo "**Most used commands:**"
    for base count in "${(@kv)cmd_counts}"; do
        echo "- \`$base\` ($count times)"
    done | sort -t'(' -k2 -rn | head -10

    if (( ${#notable[@]} > 0 )); then
        echo "\n**Notable commands:**"
        printf '%s\n' "${notable[@]}" | sort -u | head -20 | while read -r cmd; do
            echo "- \`$cmd\`"
        done
    fi
}

_collect_calendar() {
    local target_date="$1"

    [[ "$GCAL_ENABLED" != "true" ]] && return

    if ! command -v gcalcli &>/dev/null; then
        echo "*Install gcalcli for calendar integration: \`pip install gcalcli\`*"
        return
    fi

    local events
    events=$(gcalcli agenda "$target_date" "$target_date 23:59" \
        --nocolor --tsv 2>/dev/null || true)

    if [[ -z "$events" || "$events" == *"No Events Found"* ]]; then
        echo "*No calendar events on $target_date*"
        return
    fi

    local count=$(echo "$events" | wc -l | tr -d ' ')
    echo "$count events\n"

    echo "$events" | while IFS=$'\t' read -r sd st ed et title rest; do
        [[ -n "$title" ]] && echo "- **$st - $et** $title"
    done
}

_collect_claude_sessions() {
    local target_date="$1"

    if [[ ! -d "$CLAUDE_PROJECTS_DIR" ]]; then
        echo "*No Claude Code sessions directory found*"
        return
    fi
    if ! command -v jq &>/dev/null; then
        echo "*Install jq for Claude session parsing*"
        return
    fi

    local session_count=0 output=""

    for index_file in "$CLAUDE_PROJECTS_DIR"/*/sessions-index.json(N); do
        [[ -f "$index_file" ]] || continue
        local project_name=$(basename "$(dirname "$index_file")")

        local sessions
        sessions=$(jq -r --arg date "$target_date" '
            .entries[]
            | select(.created
                | split("T")[0] == $date)
            | "\(.created)\t\(.messageCount // "?")\t\(.gitBranch // "—")"
        ' "$index_file" 2>/dev/null || true)

        if [[ -n "$sessions" ]]; then
            local count=$(echo "$sessions" | wc -l | tr -d ' ')
            session_count=$((session_count + count))
            output+="**$project_name** ($count sessions)\n"

            echo "$sessions" | while IFS=$'\t' read -r ts msgs branch; do
                local time=$(echo "$ts" | sed 's/.*T//' | cut -d. -f1 | cut -d: -f1-2)
                output+="- $time — $msgs messages"
                [[ "$branch" != "—" ]] && output+=" (branch: \`$branch\`)"
                output+="\n"
            done
            output+="\n"
        fi
    done

    if [[ -n "$output" ]]; then
        echo "$session_count sessions\n"
        echo "$output"
    else
        echo "*No Claude Code sessions on $target_date*"
    fi
}

# --- Recap & Weekly subcommands ---

cmd_recap() {
    local target="${1:-today}"

    case "$target" in
        today)     local target_date=$(vault_date) ;;
        yesterday) local target_date=$(_date_yesterday) ;;
        *)         local target_date="$target" ;;
    esac

    local dow=$(_date_fmt "$target_date" "+%A")
    local month=$(echo "$target_date" | cut -d- -f2)
    local day=$(echo "$target_date" | cut -d- -f3)
    local recap_file="$VAULT_DIR/journal/$target_date.md"

    # Pull latest vault state
    if [[ -d "$VAULT_DIR/.git" ]]; then
        (cd "$VAULT_DIR" && git pull --rebase --quiet) 2>/dev/null || true
    fi

    mkdir -p "$VAULT_DIR/journal"

    # Append if file already has content, otherwise create fresh
    local append_mode=false
    if [[ -f "$recap_file" ]]; then
        local existing_size=$(wc -c < "$recap_file" | tr -d ' ')
        (( existing_size > 200 )) && append_mode=true
    fi

    {
        if $append_mode; then
            echo ""
            echo "---"
            echo ""
            echo "## Auto-Recap ($(vault_hostname))"
            echo "_Generated at $(vault_time)_"
        else
            echo "---"
            echo "created: $target_date"
            echo "type: daily-recap"
            echo "tags: [recap, journal]"
            echo "---"
            echo ""
            echo "# $dow, $month/$day"
        fi

        echo ""
        echo "## Git Activity"
        _collect_git_activity "$target_date"

        echo ""
        echo "## Claude Code Sessions"
        _collect_claude_sessions "$target_date"

        echo ""
        echo "## Shell Activity"
        _collect_shell_history "$target_date"

        echo ""
        echo "## Calendar"
        _collect_calendar "$target_date"

        echo ""
        echo "## Inbox Captures"
        local inbox_file="$VAULT_DIR/00-inbox/$target_date.md"
        if [[ -f "$inbox_file" ]]; then
            cat "$inbox_file"
        else
            echo "*No captures today*"
        fi

    } >> "$recap_file" 2>/dev/null

    # Also harvest Claude sessions as resource notes
    cmd_harvest 2>/dev/null || true

    # Commit and push
    if [[ -d "$VAULT_DIR/.git" ]]; then
        (cd "$VAULT_DIR" && git add -A && \
            git commit -m "recap: $target_date [$(vault_hostname)]" --quiet && \
            git push --quiet) 2>/dev/null || true
    fi

    echo "Recap written to $recap_file"
}

cmd_weekly() {
    local end_date="${1:-$(vault_date)}"
    local start_date=$(_date_offset "$end_date" -6)
    local week_num=$(_date_fmt "$end_date" +%V)
    local year=$(echo "$end_date" | cut -d- -f1)
    local weekly_file="$VAULT_DIR/journal/week-${year}-${week_num}.md"

    # Pull latest
    if [[ -d "$VAULT_DIR/.git" ]]; then
        (cd "$VAULT_DIR" && git pull --rebase --quiet) 2>/dev/null || true
    fi

    mkdir -p "$VAULT_DIR/journal"

    # Collect daily files
    local daily_files=()
    local current="$start_date"
    while [[ "$current" < "$end_date" || "$current" == "$end_date" ]]; do
        local daily="$VAULT_DIR/journal/$current.md"
        [[ -f "$daily" ]] && daily_files+=("$daily")
        current=$(_date_offset "$current" +1)
    done

    if (( ${#daily_files[@]} == 0 )); then
        echo "No daily recaps found for week $week_num ($start_date to $end_date)"
        return 0
    fi

    # Extract stats
    local total_commits=0 total_sessions=0
    local active_days=${#daily_files[@]}
    declare -A repo_commits project_sessions

    for file in "${daily_files[@]}"; do
        while IFS= read -r line; do
            if [[ "$line" =~ ^\*\*(.+)\*\*\ \(([0-9]+)\ commits\) ]]; then
                local repo="${match[1]}" count="${match[2]}"
                repo_commits[$repo]=$(( ${repo_commits[$repo]:-0} + count ))
                total_commits=$((total_commits + count))
            fi
        done < "$file"

        while IFS= read -r line; do
            if [[ "$line" =~ ^\*\*(.+)\*\*\ \(([0-9]+)\ sessions?\) ]]; then
                local proj="${match[1]}" count="${match[2]}"
                project_sessions[$proj]=$(( ${project_sessions[$proj]:-0} + count ))
                total_sessions=$((total_sessions + count))
            fi
        done < "$file"
    done

    # Write rollup
    {
        echo "---"
        echo "created: $(vault_date)"
        echo "type: weekly-rollup"
        echo "tags: [weekly, journal, review]"
        echo "week: $week_num"
        echo "---"
        echo ""
        echo "# Week $week_num — $start_date to $end_date"
        echo ""
        echo "## At a Glance"
        echo ""
        echo "| Metric | Count |"
        echo "|--------|-------|"
        echo "| Active days | $active_days / 7 |"
        echo "| Total commits | $total_commits |"
        echo "| Claude sessions | $total_sessions |"
        echo ""

        if (( ${#repo_commits[@]} > 0 )); then
            echo "## Repos"
            echo ""
            for repo count in "${(@kv)repo_commits}"; do
                echo "- **$repo** — $count commits"
            done | sort -t'—' -k2 -rn
            echo ""
        fi

        if (( ${#project_sessions[@]} > 0 )); then
            echo "## Claude Code Projects"
            echo ""
            for proj count in "${(@kv)project_sessions}"; do
                echo "- **$proj** — $count sessions"
            done | sort -t'—' -k2 -rn
            echo ""
        fi

        echo "## Daily Notes"
        echo ""
        current="$start_date"
        while [[ "$current" < "$end_date" || "$current" == "$end_date" ]]; do
            local dow=$(_date_fmt "$current" "+%A")
            if [[ -f "$VAULT_DIR/journal/$current.md" ]]; then
                echo "- [[$current|$dow]]"
            else
                echo "- $dow — *no recap*"
            fi
            current=$(_date_offset "$current" +1)
        done
        echo ""

        echo "## Reflection"
        echo ""
        echo "> What went well this week?"
        echo ""
        echo ""
        echo "> What could be better?"
        echo ""
        echo ""
        echo "> Focus for next week?"
        echo ""

    } > "$weekly_file"

    # Commit and push
    if [[ -d "$VAULT_DIR/.git" ]]; then
        (cd "$VAULT_DIR" && git add -A && \
            git commit -m "weekly: week $week_num [$(vault_hostname)]" --quiet && \
            git push --quiet) 2>/dev/null || true
    fi

    echo "Weekly rollup written to $weekly_file"
}

# --- Dispatch ---
case "${1:-help}" in
    add)      shift; cmd_add "$@" ;;
    process)  shift; cmd_process "$@" ;;
    edit)     shift; cmd_edit "$@" ;;
    daily)    shift; cmd_daily "$@" ;;
    search)   shift; cmd_search "$@" ;;
    sync)     shift; cmd_sync "$@" ;;
    harvest)  shift; cmd_harvest "$@" ;;
    recent|log) shift; cmd_recent "$@" ;;
    recap)    shift; cmd_recap "$@" ;;
    weekly)   shift; cmd_weekly "$@" ;;
    help|-h|--help) cmd_help ;;
    *) echo "Unknown command: $1. Run 'vault help' for usage." >&2; exit 1 ;;
esac
